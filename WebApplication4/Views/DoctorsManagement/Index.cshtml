@model List<WebApplication4.Models.Doctors>
@{
    // 获取当前页码
    var pageQuery = Context.Request.Query["pageIndex"].FirstOrDefault() ?? "1";
    int currentPage = int.Parse(pageQuery);
    ViewData["Title"] = "医生管理";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- 主内容区（完全匹配你的CSS样式） -->
<div class="admin-content">
    <div class="admin-header">
        <h1>医生管理</h1>
        <div class="admin-user-info">
            <span>当前登录：管理员</span>
        </div>
    </div>

    <!-- 医生列表 -->
    <div class="admin-users-list">
        <h2>医生列表</h2>
        <div class="users-table-container">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>医生ID</th>
                        <th>医生姓名</th>
                        <th>性别</th>
                        <th>所属科室</th>
                        <th>职称</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var doctor in Model)
                        {
                            <tr>
                                <td>@doctor.DoctorId</td>
                                <td>@doctor.DoctorName</td>
                                <td>@doctor.Gender</td>
                                <td>@doctor.Department</td>
                                <td>@doctor.Title</td>
                                <td>@doctor.Status</td>
                                <td>
                                    <button class="btn btn-sm btn-primary">编辑</button>
                                    <button class="btn btn-sm btn-danger">删除</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">暂无医生数据</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination">
            @* 上一页：使用 @Url.Action 生成链接 *@
            @if (currentPage > 1)
            {
                <a href="@Url.Action("Index", "DoctorsManagement", new { pageIndex = currentPage - 1 })" class="page-link">
                    上一页
                </a>
            }
            else
            {
                <span class="page-link" disabled>上一页</span>
            }

            <span>第 @currentPage 页</span>

            @* 下一页：使用 @Url.Action 生成链接 *@
            <a href="@Url.Action("Index", "DoctorsManagement", new { pageIndex = currentPage + 1 })" class="page-link">
                下一页
            </a>
        </div>
    </div>
</div>