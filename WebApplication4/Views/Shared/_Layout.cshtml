@using WebApplication4
@using MySqlConnector;

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - 小猫健康院</title>

    <!-- 引入猫爪图标库 -->
    <link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- 引入独立的小猫风格CSS -->
   
    <link rel="stylesheet" href="~/css/kitten-health.css" />
    <link rel="stylesheet" href="~/css/kitten-user.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div id="kitten-wrapper">
        <header>
            <nav aria-label="主导航">
                <div>
                    <a href="/">
                        <div aria-hidden="true"><i class="fa-solid fa-paw"></i></div>
                        <div>小猫健康院</div>
                    </a>

                    <div role="navigation" aria-label="页面链接">
                        <a href="/Home/Index">主页</a>
                        <a href="/Gy/Index">关于</a>
                        @{
                                if (User.Identity!.IsAuthenticated)
                                {
                                    <a href="/UserCenter/Index">个人中心</a>                
                                }
                            }
                    </div>
                </div>

                <div class="nav-actions">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="nav-user">
                            
                            <img src="@(string.IsNullOrEmpty(ViewBag.Avatar as string) ? "/images/avatar/default.png" : ViewBag.Avatar)"
                                 class="nav-avatar" alt="用户头像" onclick="window.location.href='@Url.Action("Index","UserCenter")'">
                            <span>@User.Identity.Name</span>
                        </div>
                        <form method="post" action="/Login/Logout" style="display:inline; margin:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit">退出</button>
                        </form>
                    }
                    else
                    {
                        <a href="/Zc/Index"><i class="fa-regular fa-user" aria-hidden="true"></i> 注册</a>
                        <a href="/Login/Index"><i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i> 登录</a>
                    }
                </div>
            </nav>
        </header>

        <main role="main">
            @RenderBody()
        </main>

        <footer>
            &copy; 2026 - 小猫健康院 · WebApplication4
        </footer>
    </div>

    <!-- Bootstrap JS 放在底部优化加载 -->
    <script src="~/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
<script>
    
     function connectWebSocket()
     {
         var socket = new WebSocket("ws://localhost:5000/ws");
         socket.onmessage = function (event) {
             var data = JSON.parse(event.data);
             console.log(data);
             if (data.type === "message") {
                 var messageElement = document.createElement("div");
                 messageElement.textContent = data.message;
                 document.getElementById("messages").appendChild(messageElement);
             }
         };
     }
    // 发送消息通用函数（适配你的后端 WebMessage 类）
    function sendMessage(data="", type, toname, torole) {
    // 1. 校验WebSocket是否连接成功
    if (!ws || ws.readyState !== WebSocket.OPEN) {
        console.log("WebSocket未连接，发送失败！");
        return;
    }

    // 2. 构造消息（严格匹配后端字段：大小写完全一致！）
    var message = {
        Type: type,        // 消息类型：chat / queryorder
        Toname: toname,    // 接收人
        Torole: torole,    // 接收角色
        Time: new Date().format("yyyy-MM-dd HH:mm:ss"), // 自动生成时间（大写T！）
        Data: data         // 消息内容
    };

    // 3. 发送JSON字符串
    ws.send(JSON.stringify(message));
    console.log("发送成功：", message);
}

// 辅助：时间格式化工具（必须加，不然时间格式乱）
    Date.prototype.format = function (fmt) {
    var o = {
        "M+": this.getMonth() + 1,
        "d+": this.getDate(),
        "H+": this.getHours(),
        "m+": this.getMinutes(),
        "s+": this.getSeconds()
    };
    if (/(y+)/.test(fmt)) fmt = fmt.replace(RegExp.$1, (this.getFullYear() + "").substr(4 - RegExp.$1.length));
    for (var k in o)
        if (new RegExp("(" + k + ")").test(fmt)) fmt = fmt.replace(RegExp.$1, (RegExp.$1.length == 1) ? (o[k]) : (("00" + o[k]).substr(("" + o[k]).length)));
    return fmt;
};
</script>