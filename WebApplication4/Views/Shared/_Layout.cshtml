@using WebApplication4

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - WebApplication4</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    @RenderSection("Styles", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- 核心修改1：container → container-fluid，新增自定义类清除边距 -->
    <div class="container-fluid body-content" style="margin:0; padding:0; width:100%;">
        <header>
            <!-- 核心修改2：导航栏容器加p-0，清除默认padding -->
            <nav class="navbar navbar-expand-lg navbar-light bg-light">
                <div class="container-fluid p-0">
                    <a class="navbar-brand ms-3" href="/">MyApp</a> <!-- 仅保留左侧小内边距，避免logo贴边 -->
                    <button class="navbar-toggler me-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-3">
                            <li class="nav-item">
                                <a class="nav-link" href="/">主页</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/UserCenter/Index">个人中心</a>
                            </li>
                        </ul>
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <ul class="navbar-nav me-3">
                                <li class="nav-item">
                                    <span class="nav-link">欢迎，@User.Identity.Name</span>
                                </li>
                                <li class="nav-item">
                                    <form class="d-inline" method="post" action="/Login/Logout">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="nav-link btn btn-link" style="display:inline;padding:0;border:none;">退出</button>
                                    </form>
                                </li>
                            </ul>
                        }
                        else
                        {
                            <ul class="navbar-nav me-3">
                                <li class="nav-item">
                                    <a class="nav-link" href="/Zc/Index">注册</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/Login/Index">登录</a>
                                </li>
                            </ul>
                        }
                    </div>
                </div>
            </nav>
        </header>

        <!-- 核心修改3：main标签清除默认padding，确保和主页样式兼容 -->
        <main role="main" class="pb-3" style="padding:0; margin:0;">
            @RenderBody()
        </main>

        <footer class="border-top footer text-muted">
            <!-- 核心修改4：页脚容器加w-100，清除默认max-width -->
            <div class="container-fluid w-100" style="padding:1rem; margin:0;">
                &copy; 2026 - WebApplication4
            </div>
        </footer>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>