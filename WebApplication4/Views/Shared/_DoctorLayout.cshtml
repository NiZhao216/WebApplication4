<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - 医生工作台</title>

    <!-- 引入Font Awesome图标库 -->
    <link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- 引入医生专用样式 -->
    <link rel="stylesheet" href="~/css/doctor-layout.css" />

    @RenderSection("Styles", required: false)
    <style>
        /* 新增：消息通知样式（不影响原有布局） */
        .message-box {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 300px;
            max-height: 400px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
            padding: 10px;
            z-index: 9999;
            overflow-y: auto;
        }
        .chat-item {
            padding: 5px;
            margin: 5px 0;
            background: #f5f5f5;
            border-radius: 4px;
        }
        .order-item {
            padding: 8px;
            margin: 5px 0;
            background: #e3f2fd;
            border-left: 3px solid #2196f3;
        }
    </style>
</head>
<body>
    <div class="doctor-wrapper">
        <!-- 侧边栏 -->
        <aside class="doctor-sidebar">
            <div class="sidebar-header">
                <div class="logo-icon">
                    <i class="fas fa-user-md"></i>
                </div>
                <h2>医生工作台</h2>
            </div>

            <nav class="sidebar-nav">
                <a href="/DoctorHome/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "DoctorHome" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-home"></i>
                    <span>首页</span>
                </a>
                <a href="/Appointments/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointments" ? "active" : "")">
                    <i class="fas fa-calendar-check"></i>
                    <span>预约管理</span>
                </a>
                <a href="/Doctor/Patients" class="nav-item">
                    <i class="fas fa-users"></i>
                    <span>患者管理</span>
                </a>
                <a href="/Doctor/MedicalRecords" class="nav-item">
                    <i class="fas fa-file-medical"></i>
                    <span>病历管理</span>
                </a>
                <a href="/Doctor/Profile" class="nav-item">
                    <i class="fas fa-user-circle"></i>
                    <span>个人资料</span>
                </a>
                <a href="/Doctor/Settings" class="nav-item">
                    <i class="fas fa-cog"></i>
                    <span>系统设置</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <form method="post" action="/Doctor/Logout" class="logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>退出登录</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- 主内容区 -->
        <div class="doctor-main">
            <!-- 顶部导航栏 -->
            <header class="doctor-header">
                <div class="header-left">
                    <button class="menu-toggle" id="menuToggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1>@ViewBag.Title</h1>
                </div>

                <div class="header-right">
                    <div class="doctor-info">
                        <img src="@(string.IsNullOrEmpty(ViewBag.Avatar as string) ? "/images/avatar/default.png" : ViewBag.Avatar)" 
                             alt="医生头像" class="header-avatar">
                        <div class="doctor-details">
                            <span class="doctor-name">@ViewBag.DoctorName</span>
                            <span class="doctor-title">@ViewBag.Department</span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- 页面内容 -->
            <main class="doctor-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- 新增：消息通知容器 -->
    <div class="message-box" id="messageBox">
        <h4>消息通知</h4>
    </div>

    @RenderSection("Scripts", required: false)

    <script>
        // 侧边栏切换
        document.getElementById('menuToggle')?.addEventListener('click', function() {
            document.querySelector('.doctor-sidebar').classList.toggle('collapsed');
            document.querySelector('.doctor-main').classList.toggle('expanded');
        });

        // ====================== WebSocket 核心代码 ======================
        let ws;
        // 连接后端WebSocket
        function connectWebSocket() {
            // 生产环境替换为你的域名 ws://xxx.com/Websocket
            const wsUrl = `ws://${window.location.host}/Websocket`;
            ws = new WebSocket(wsUrl);

            // 连接成功
            ws.onopen = function () {
                console.log("医生端WebSocket连接成功");
            };

            // 接收后端消息（聊天+订单）
            ws.onmessage = function (event) {
                const msg = JSON.parse(event.data);
                const messageBox = document.getElementById('messageBox');

                switch (msg.Type) {
                    // 接收聊天消息
                    case "chat":
                        const chatHtml = `
                            <div class="chat-item">
                                <p>${msg.Time}</p>
                                <p>患者消息：${msg.Data}</p>
                            </div>
                        `;
                        messageBox.innerHTML += chatHtml;
                        break;

                    // 接收订单/预约列表
                    case "order":
                        const orderList = msg.Data;
                        let orderHtml = `<div class="order-item"><p>${msg.Time} 新预约</p>`;
                        orderList.forEach(order => {
                            orderHtml += `
                                <p>订单号：${order.Orid}</p>
                                <p>宠物：${order.CatName}</p>
                                <p>状态：${order.Status}</p>
                                <hr>
                            `;
                        });
                        orderHtml += `</div>`;
                        messageBox.innerHTML += orderHtml;
                        break;
                }
                // 滚动到底部
                messageBox.scrollTop = messageBox.scrollHeight;
            };

            // 断开重连
            ws.onclose = function () {
                console.log("连接断开，5秒后重连...");
                setTimeout(connectWebSocket, 5000);
            };

            // 连接错误
            ws.onerror = function () {
                console.log("WebSocket连接失败");
            };
        }

        // 页面加载后自动连接
        window.onload = connectWebSocket;
    </script>
</body>
</html>