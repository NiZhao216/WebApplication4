@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "注册";
}

<!-- 引入注册页专属小猫风格CSS -->
@section Styles {
    <link rel="stylesheet" href="~/css/kitten-register.css" />
}

<script>
    window.onload = function() {
        var message = "@Html.Raw(ViewBag.Message)";
        if (message && message.trim() !== "") {
            alert(message);
        }
    };
</script>

<div class="zc-wrap page-card">
    <h2><i class="fa-solid fa-cat" aria-hidden="true"></i> 小猫注册站</h2>

    <form method="post" action="/Zc/Index" onsubmit="return kong()" class="form-grid">
        <div>
            <label for="username">用户名</label>
            <input type="text" id="username" name="username" placeholder="请输入用户名（不能含空格）" />
        </div>

        <div>
            <label for="password">密码</label>
            <input type="password" id="password" name="password" placeholder="请输入密码" />
        </div>

        <div>
            <label for="password1">确认密码</label>
            <input type="password" id="password1" name="password1" placeholder="请再次输入密码" />
        </div>

        <div class="actions">
            <button type="submit" class="btn-cta">注册</button>
            <button type="button" class="btn-secondary" onclick="window.location.href='/Login/Index'">返回登录页面</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="@(Url.Content("~/js/zc.js"))" asp-append_version="true"></script>
}