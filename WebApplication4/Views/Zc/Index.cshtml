@{
    ViewBag.Title = "注册页面";
    Layout = null; // 独立页面，不继承布局（如需继承可删除此行）
}

<!-- 引入Font Awesome图标库（小猫/猫爪/锁图标） -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
    /* 全局样式 - 匹配小猫主题 */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Microsoft YaHei", "Heiti SC", sans-serif;
    }

    body {
        background-color: #f9f6f0; /* 奶白底色（猫窝质感） */
        color: #5a4b38;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 20px;
    }

    /* 注册表单容器（猫窝样式） */
    .register-container {
        background-color: #fff;
        border-radius: 24px;
        padding: 40px 30px;
        box-shadow: 0 6px 20px rgba(139, 90, 43, 0.12);
        border: 1px solid #f0e6d6;
        width: 100%;
        max-width: 450px;
    }

    /* 注册标题（带猫咪图标） */
    .register-title {
        text-align: center;
        font-size: 26px;
        color: #8b5a2b; /* 暖棕主色 */
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .register-title i {
        animation: cat-wave 3s ease-in-out infinite;
    }

    /* 猫咪摆动动画（修复Razor解析：@@替代） */
    @@keyframes cat-wave {
        0%, 100% { transform: rotate(0deg); }
        50% { transform: rotate(12deg); }
    }

    /* 输入框组（带小猫/锁图标） */
    .input-group {
        margin-bottom: 20px;
        position: relative;
    }

    .input-group label {
        display: block;
        margin-bottom: 8px;
        color: #8b5a2b;
        font-weight: 500;
    }

    .input-group input {
        width: 100%;
        padding: 12px 15px 12px 45px; /* 左边留图标位置 */
        border: 1px solid #f0e6d6;
        border-radius: 12px;
        background-color: #f9f6f0;
        font-size: 16px;
        color: #5a4b38;
        transition: all 0.3s ease;
    }

    .input-group input:focus {
        outline: none;
        border-color: #f4a460; /* 浅橘高亮 */
        box-shadow: 0 0 0 3px rgba(244, 164, 96, 0.15);
    }

    /* 输入框前的图标 */
    .input-group i {
        position: absolute;
        left: 15px;
        top: 38px;
        color: #8b5a2b;
        font-size: 18px;
    }

    /* 按钮样式组 */
    .btn-group {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }

    /* 注册按钮（小猫风格） */
    .register-btn {
        flex: 1;
        padding: 12px;
        background-color: #8b5a2b;
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .register-btn:hover {
        background-color: #a67c52;
        transform: scale(1.02);
        box-shadow: 0 4px 10px rgba(139, 90, 43, 0.2);
    }

    /* 返回按钮（浅色系） */
    .back-btn {
        flex: 1;
        padding: 12px;
        background-color: #f0e6d6;
        color: #8b5a2b;
        border: 1px solid #8b5a2b;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        background-color: #f4a460;
        color: #fff;
        border-color: #f4a460;
    }
</style>

<!-- 注册表单容器 -->
<div class="register-container">
    <!-- 注册标题（带猫咪图标） -->
    <h2 class="register-title">
        <i class="fas fa-cat"></i>
        小猫注册站
    </h2>

    <!-- 表单（保留原有验证函数kong()） -->
    <form method="post" action="/Zc/Index" onsubmit="return kong()">
        <!-- 用户名输入框（带猫咪用户图标） -->
        <div class="input-group">
            <label for="username">用户名</label>
            <i class="fas fa-user-cat"></i>
            <input type="text" id="username" name="username" placeholder="请输入用户名（不能含空格）">
        </div>

        <!-- 密码输入框（带锁图标） -->
        <div class="input-group">
            <label for="password">密码</label>
            <i class="fas fa-lock"></i>
            <input type="password" id="password" name="password" placeholder="请输入密码">
        </div>

        <!-- 确认密码输入框（带重复锁图标） -->
        <div class="input-group">
            <label for="password1">确认密码</label>
            <i class="fas fa-lock-open"></i>
            <input type="password" id="password1" name="password1" placeholder="请再次输入密码">
        </div>

        <!-- 按钮组（注册+返回） -->
        <div class="btn-group">
            <input type="submit" value="注册" class="register-btn">
            <input type="button" value="返回登录页面" onclick="window.location.href='/Login/Index'" class="back-btn">
        </div>
    </form>
</div>

<!-- 原有验证逻辑（完全保留，仅格式化） -->
<script type="text/javascript">
    // 页面加载弹窗提示（ViewBag.Message）
    window.onload = function() {
        var message = "@Html.Raw(ViewBag.Message)";
        if (message && message.trim() !== "") {
            alert(message);
        }
    };

    // 表单验证函数（保留所有逻辑）
    function kong() {
        var name = document.getElementById("username").value;
        var pwd = document.getElementById("password").value;
        var pwd1 = document.getElementById("password1").value;

        // 非空验证
        if (name === "" || pwd === "" || pwd1 === "") {
            alert("用户名/密码不能为空！");
            return false;
        }

        // 用户名含空格验证
        if (name.indexOf(' ') !== -1) {
            alert("用户名不能包含空格！");
            return false;
        }

        // 密码一致性验证
        if (pwd !== pwd1) {
            alert("两次输入的密码不一致！");
            return false;
        }

        return true; // 验证通过，提交表单
    }
</script>