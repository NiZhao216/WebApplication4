@model WebApplication4.Models.User;
@{
    ViewBag.Title = "主页";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Avatar = Model?.avatar;
}
<link href="~/css/home.css" rel="stylesheet" />
<div class="home-page">
    <div class="home-container">
        <div class="welcome-card">
            <div class="welcome-title">
                <i class="fas fa-cat icon-pink"></i>
                欢迎，普通用户
            </div>
            <div class="welcome-desc">这里是你的个人主页 —— 快速访问常用功能与信息概览。</div>
        </div>

        <div class="card-grid">
            <div class="function-card">
                <h3><i class="fas fa-paw icon-pink"></i> 小猫档案</h3>
                <p>查看并编辑小猫档案。</p>
                <a href="@Url.Action("Index", "CatList")" class="card-link link-pink">立即管理 →</a>
            </div>
            <div class="function-card">
                <h3><i class="fas fa-bell icon-orange"></i> 最新消息</h3>
                <p>系统通知、活动和推荐内容汇总。</p>
                <a href="#" class="card-link link-orange">查看详情 →</a>
            </div>
            <div class="function-card">
                <h3><i class="fas fa-calendar-check icon-blue"></i> 快速预约挂号</h3>
                <p>预约兽医、选择时间，免排队就诊</p>
                <a href="@Url.Action("Index", "Yuy")" class="card-link link-blue">立即预约 →</a>
            </div>
            <div class="function-card">
                <h3><i class="fas fa-file-medical icon-green"></i> 诊疗病历记录</h3>
                <p>查看历史病历、检查报告、处方单、消费记录</p>
                <a href="@Url.Action("Index", "Order")"class="card-link link-green">查看记录 →</a>
            </div>
            <div class="function-card">
                <h3><i class="fas fa-comments icon-purple"></i> 在线问诊咨询</h3>
                <p>紧急情况图文咨询兽医，足不出户问诊</p>
                <a href="#" class="card-link link-purple">立即咨询 →</a>
            </div>
            <div class="function-card">
                <h3><i class="fas fa-pills icon-red"></i> 用药护理指导</h3>
                <p>医生专属喂药、术后护理、日常养护建议</p>
                <a href="#" class="card-link link-red">查看指南 →</a>
            </div>
        </div>
    </div>
</div>