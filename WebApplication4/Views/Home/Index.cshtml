@model WebApplication4.Models.User;
@{
    ViewBag.Title = "主页";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Avatar = Model?.avatar;
}


<!-- 样式引用已移除 -->

<!-- 外层home-page：实现全屏奶白背景（无左右padding） -->
<div style="position:relative;">
    <!-- 新增home-content容器：内容居中+保留左右内边距，解决侧边留白 -->
    <div>
        <div>
            <div>
                <i class="fas fa-cat"></i>
                欢迎，普通用户
            </div>
            <div>这里是你的个人主页 —— 快速访问常用功能与信息概览。</div>
        </div>

        <div>
            <div>
                <h3><i class="fas fa-paw"></i> 个人信息</h3>
                <p>查看并编辑个人资料、联系方式等。</p>
            </div>
            <div>
                <h3><i class="fas fa-bell"></i> 最新消息</h3>
                <p>系统通知、活动和推荐内容汇总。</p>
            </div>
        </div>
    </div>
</div>