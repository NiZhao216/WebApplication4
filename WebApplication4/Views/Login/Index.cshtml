@{
    ViewBag.Title = "小猫登录页面";
}

<!-- 引入登录页专属CSS + 图标库 -->
<link rel="stylesheet" href="~/css/kitten-login.css" />

<!-- 登录表单容器 -->
<div class="login-container">
    <h2>
        <i class="fas fa-cat"></i>
        小猫登录站
    </h2>

    <form method="post" action="/Login/Index" onsubmit="return d()" class="login-form">
        <div class="form-group">
            <label for="username">用户名</label>
            <input type="text" id="username" name="username" placeholder="请输入用户名">
        </div>

        <div class="form-group">
            <label for="password">密码</label>
            <input type="password" id="password" name="password" placeholder="请输入密码">
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMsg))
            {
                <div class="error-msg">@Html.Raw(ViewBag.ErrorMsg)</div>
            }
        </div>

        <div>
            <button type="submit" class="login-btn">登录</button>
        </div>

        <div class="register-link">
            <a href="/Zc/Index"><i class="fas fa-paw"></i> 还没有账号？点击注册</a>
        </div>
    </form>
</div>

<!-- 原有提示弹窗逻辑（保留） -->
<script type="text/javascript">
    window.onload = function () {
        var message = "@Html.Raw(TempData["Message"])";
        if (message && message.trim() !== "")
            alert(message);
    }
    function  d()
    {
        var username=document.getElementById("username").value;
        var pwd=document.getElementById("password").value;
        if(username.trim()==""||pwd.trim()=="")
        {
            alert("账号或密码不能为空");
            return false;
        }
        else
            return true;
    }
</script>