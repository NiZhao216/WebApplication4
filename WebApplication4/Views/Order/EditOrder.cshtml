@model WebApplication4.Models.Orders
@{
    ViewBag.Title = "修改订单";
}

<link href="~/css/order.css" rel="stylesheet" />

<div class="order-page">
    <div class="order-header">
        <h2><i class="fas fa-edit"></i> 修改订单</h2>
    </div>

    <div class="order-card">
        <div class="order-header-info">
            <div class="order-id">订单号: @Model.Orid</div>
            <div class="order-status @GetStatusClass(Model.Status)">@Model.Status</div>
        </div>

        <div class="order-body">
            <form method="post" action="@Url.Action("UpdateOrder", "Order")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Orid" value="@Model.Orid" />
                
                <div class="order-info-row">
                    <div class="order-info-item">
                        <div class="form-group">
                            <label><i class="fas fa-cat"></i> 宠物名称</label>
                            <input type="text" name="CatName" value="@Model.CatName" class="form-control" required />
                        </div>
                    </div>
                    <div class="order-info-item">
                        <div class="form-group">
                            <label><i class="fas fa-user-md"></i> 医生</label>
                            <input type="text" name="DoctorName" value="@Model.DoctorName" class="form-control" required />
                        </div>
                    </div>
                </div>
                
                <div class="order-info-row">
                    <div class="order-info-item">
                        <div class="form-group">
                            <label><i class="fas fa-stethoscope"></i> 预约项目</label>
                            <input type="text" name="ServiceType" value="@Model.ServiceType" class="form-control" required />
                        </div>
                    </div>
                    <div class="order-info-item">
                        <div class="form-group">
                            <label><i class="fas fa-calendar-alt"></i> 预约时间</label>
                            <input type="datetime-local" name="AppointmentTime" value="@Model.AppointmentTime.ToString("yyyy-MM-ddTHH:mm")" class="form-control" required />
                        </div>
                    </div>
                </div>
                
                <div class="form-group">
                    <label><i class="fas fa-phone"></i> 联系电话</label>
                    <input type="tel" name="Phone" value="@Model.Phone" class="form-control" required />
                </div>
                
                <div class="form-group">
                    <label><i class="fas fa-comment-medical"></i> 症状/需求描述</label>
                    <textarea name="Description" class="form-control" rows="4">@Model.Description</textarea>
                </div>
                
                <div class="order-footer">
                    <button type="submit" class="btn btn-primary">保存修改</button>
                    <a href="@Url.Action("Index", "Order")" class="btn btn-cancel">取消</a>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    public string GetStatusClass(string status)
    {
        return status switch
        {
            "待确认" => "status-pending",
            "已确认" => "status-confirmed",
            "已完成" => "status-completed",
            "已取消" => "status-cancelled",
            _ => ""
        };
    }
}