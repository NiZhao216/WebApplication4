@model WebApplication4.Models.Orders
@{
    ViewBag.Title = "售后服务";
}

<link href="~/css/order.css" rel="stylesheet" />

<div class="order-page">
    <div class="order-header">
        <h2><i class="fas fa-headset"></i> 售后服务</h2>
    </div>

    <div class="order-card">
        <div class="order-header-info">
            <div class="order-id">订单号: @Model.Id</div>
            <div class="order-status @GetStatusClass(Model.Status)">@Model.Status</div>
        </div>

        <div class="order-body">
            <div class="order-info-row">
                <div class="order-info-item">
                    <span class="info-label"><i class="fas fa-cat"></i> 宠物名称:</span>
                    <span class="info-value">@Model.CatName</span>
                </div>
                <div class="order-info-item">
                    <span class="info-label"><i class="fas fa-user-md"></i> 医生:</span>
                    <span class="info-value">@Model.DoctorName</span>
                </div>
            </div>

            <div class="order-info-row">
                <div class="order-info-item">
                    <span class="info-label"><i class="fas fa-stethoscope"></i> 预约项目:</span>
                    <span class="info-value">@Model.ServiceType</span>
                </div>
                <div class="order-info-item">
                    <span class="info-label"><i class="fas fa-calendar-alt"></i> 预约时间:</span>
                    <span class="info-value">@Model.AppointmentTime.ToString("yyyy-MM-dd HH:mm")</span>
                </div>
            </div>
        </div>

        <div class="order-body">
            <h3><i class="fas fa-clipboard-list"></i> 提交售后申请</h3>
            <form method="post" action="@Url.Action("SubmitAfterSales", "Order")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.Id" />
                
                <div class="form-group">
                    <label><i class="fas fa-exclamation-circle"></i> 问题类型</label>
                    <select name="issueType" class="form-control" required>
                        <option value="">请选择问题类型</option>
                        <option value="服务质量">服务质量</option>
                        <option value="治疗效果">治疗效果</option>
                        <option value="医生态度">医生态度</option>
                        <option value="费用问题">费用问题</option>
                        <option value="其他问题">其他问题</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label><i class="fas fa-comment-alt"></i> 问题描述</label>
                    <textarea name="description" class="form-control" rows="5" required></textarea>
                </div>
                
                <div class="form-group">
                    <label><i class="fas fa-phone"></i> 联系方式</label>
                    <input type="text" name="contactMethod" value="@Model.Phone" class="form-control" required />
                </div>
                
                <div class="order-footer">
                    <button type="submit" class="btn btn-primary">提交申请</button>
                    <a href="@Url.Action("Index", "Order")" class="btn btn-cancel">返回订单列表</a>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    public string GetStatusClass(string status)
    {
        return status switch
        {
            "待确认" => "status-pending",
            "已确认" => "status-confirmed",
            "已完成" => "status-completed",
            "已取消" => "status-cancelled",
            _ => ""
        };
    }
}