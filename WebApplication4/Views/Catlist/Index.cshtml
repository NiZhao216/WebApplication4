@model List<WebApplication4.Models.Cats>
@{
    ViewBag.Title = "我的猫咪档案";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/css/kitten-cat-list.css" rel="stylesheet" />

<script type="text/javascript">
    window.onload=function(){
        var message = "@Html.Raw(TempData["Msg"])";
        if(message!="")
        alert(message);
    };
</script>
<div class="cat-list-wrapper">
    <div class="cat-list-container">
        <div class="cat-list-title">
            <i class="fas fa-cat"></i> 我的猫咪管理
        </div>

        <!-- 按钮区域 --> 
        <div class="cat-list-actions">
            <!-- 新建按钮 -->
            <a href="@Url.Action("InCreatedex", "Catlist")" class="btn-add">
                <i class="fas fa-plus"></i> 新建
            </a>

            <!-- 有猫咪才显示编辑按钮 -->
            @if (Model.Any())
            {
                <button id="editBtn" class="btn-edit">
                    <i class="fas fa-edit"></i> 编辑
                </button>
            }
        </div>

        <!-- 猫咪列表 -->
        @if (!Model.Any())
        {
            <div class="empty-box">
                <i class="fas fa-paw"></i>
                <p>暂无猫咪档案</p>
            </div>
        }
        else
        {
            <div class="cat-table">
                <!-- ✅ 新增：表头标题行（与列表列一一对应） -->
                <div class="cat-row cat-header">
                    <div class="nav-user"><strong>头像</strong></div>
                    <div class="cat-info"><strong>猫咪昵称</strong></div>
                    <div class="cat-info"><strong>性别</strong></div>
                    <div class="cat-info"><strong>品种</strong></div>
                    <div class="cat-info"><strong>操作</strong></div> <!-- 操作列标题 -->
                </div>

                @foreach (var cat in Model)
                {
                    <div class="cat-row">
                        <div class="nav-user">
                            <img src="@(string.IsNullOrEmpty(cat?.avatar) ? "/images/catavatar/default.png" : cat.avatar)"
                                 class="nav-avatar" alt="用户头像" onclick="window.location.href='@Url.Action("Index", "Cat", new { catName = cat.CatName })'">
                        </div>
                        <div class="cat-info">@cat.CatName</div>
                        <div class="cat-info">@cat.Gender</div>
                        <div class="cat-info">@cat.Breed</div>

                        <!-- 操作按钮容器 - 默认隐藏 -->
                        <div class="cat-operate" style="display: none;">
                            <a href="@Url.Action("Index", "Cat", new { catName = cat.CatName })" class="btn-blue">
                                编辑档案
                            </a>
                            <a href="@Url.Action("Delete", "Catlist", new { catName = cat.CatName })"
                                   class="btn-red"
                                   onclick="return confirm('确定删除？')">
                                删除
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- JS交互 - 稳定切换 -->
<script>
    const editBtn = document.getElementById('editBtn');
    if (editBtn) {
        let isEditing = false; // 标记编辑状态
        editBtn.onclick = function () {
            isEditing = !isEditing;
            const operates = document.querySelectorAll('.cat-operate');
            
            // 切换操作按钮显示/隐藏
            operates.forEach(item => {
                item.style.display = isEditing ? 'flex' : 'none';
            });

            // 切换按钮文字和图标
            this.innerHTML = isEditing
                ? '<i class="fas fa-check"></i> 完成编辑'
                : '<i class="fas fa-edit"></i> 编辑';
        }
    }
</script>