@{
    ViewBag.Title = "医生登录页面";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - 小猫健康院</title>
    <!-- 引入Font Awesome图标库 -->
    <link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- 引入医生登录页专属CSS -->
    <link rel="stylesheet" href="~/css/doctor-login.css" />
</head>
<body>
    <div class="doctor-login-page">
        <div class="login-container">
            <div class="login-header">
                <div class="logo-icon">
                    <i class="fas fa-user-md"></i>
                </div>
                <h2>医生登录</h2>
                <p class="login-subtitle">小猫健康院 · 专业医疗服务平台</p>
            </div>

            <form method="post" action="/DoctorLogin/Login" onsubmit="return validateForm()" class="login-form">
                <div class="form-group">
                    <label for="username">
                        <i class="fas fa-user"></i>
                        用户名
                    </label>
                    <input type="text" id="username" name="id" placeholder="请输入医生用户名">
                </div>

                <div class="form-group">
                    <label for="password">
                        <i class="fas fa-lock"></i>
                        密码
                    </label>
                    <input type="password" id="password" name="pwd" placeholder="请输入密码">
                    @if (!string.IsNullOrEmpty(ViewBag.ErrorMsg))
                    {
                        <div class="error-msg">
                            <i class="fas fa-exclamation-circle"></i>
                            @Html.Raw(ViewBag.ErrorMsg)
                        </div>
                    }
                </div>

                <div class="form-options">
                    <label class="remember-me">
                        <input type="checkbox" name="remember" id="remember">
                        <span>记住我</span>
                    </label>
                    <a href="#" class="forgot-password">忘记密码？</a>
                </div>

                <div>
                    <button type="submit" class="login-btn">
                        <i class="fas fa-sign-in-alt"></i>
                        登录
                    </button>
                </div>

                <div class="login-links">
                    <a href="/Login/Index"><i class="fas fa-paw"></i> 用户登录</a>
                    <a href="/AdminLogin/Index"><i class="fas fa-user-shield"></i> 管理员登录</a>
                </div>
            </form>
        </div>
    </div>

    <script type="text/javascript">
        window.onload = function () {
            var message = "@Html.Raw(TempData["Message"])";
            if (message && message.trim() !== "") {
                alert(message);
            }
        }

        function validateForm() {
            var username = document.getElementById("username").value;
            var password = document.getElementById("password").value;

            if (username.trim() === "" || password.trim() === "") {
                alert("用户名或密码不能为空");
                return false;
            }
            return true;
        }
    </script>
</body>
</html>
