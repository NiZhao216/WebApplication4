@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "个人中心";
}

@section Styles {
    <link rel="stylesheet" href="~/css/usercenter.css" asp-append-version="true" />
}

<div class="user-form-wrapper">
    <h2 class="page-title">
        <i class="fas fa-user-circle"></i>
        个人中心
    </h2>

    <form asp-controller="UserCenter" asp-action="Save" method="post" class="user-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="0" />

        <div class="form-item">
            <label class="form-label">用户名</label>
            <input type="text" name="username" class="form-input" value="@ViewBag.Username" />
        </div>

        <div class="form-item">
            <label class="form-label">邮箱</label>
            <input type="email" name="email" class="form-input" value="@ViewBag.Email" />
        </div>

        <div class="form-item">
            <label class="form-label">手机号</label>
            <input type="text" name="phone" class="form-input" value="@ViewBag.Phone" />
        </div>

        <div class="form-item">
            <label class="form-label">年龄</label>
            <input type="text" name="age" class="form-input" value="@ViewBag.Age" />
        </div>

        <div class="form-item">
            <label class="form-label">性别</label>
            <input type="text" name="sex" class="form-input" value="@ViewBag.Sex" />
        </div>

        <div class="form-item">
            <label class="form-label">生日</label>
            <input type="date" name="by" class="form-input" value="@ViewBag.By" />
        </div>

        <div class="form-item full-width">
            <label class="form-label">个人简介</label>
            <textarea name="pr" class="form-input">@ViewBag.Pr</textarea>
        </div>

        <div class="form-item full-width">
            <label class="form-label">详细地址</label>
            <input type="text" name="address" class="form-input" value="@ViewBag.Address" />
        </div>

        <div class="btn-group">
            <button type="submit"><i class="fas fa-save"></i> 保存信息</button>
            <button type="reset" type="button"><i class="fas fa-redo"></i> 重置</button>
        </div>
    </form>
</div>
