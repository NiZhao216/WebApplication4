@model WebApplication4.Models.User;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "个人中心";
    ViewBag.Avatar = Model?.avatar;
}

<!-- 引入个人中心小猫风格CSS -->
@section Styles {
    <link rel="stylesheet" href="~/css/kitten-user.css" />
}

<script type="text/javascript">
    window.onload=function(){
        var message = "@Html.Raw(TempData["Message"])";
        if(message!="")
        alert(message);
    };

    // 头像预览功能（完全保留）
    function previewAvatar(s)
    {
        if(s.files&&s.files[0]){
            var reder = new FileReader();
            reder.onload= function(e)
            {
                document.getElementById("avatar").src = e.target.result;
            }
            reder.readAsDataURL(s.files[0]);
        }
    }
</script>

<div class="user-wrap">
    <h2>
        <i class="fas fa-user-circle"></i>
        个人中心
    </h2>

    <form asp-controller="UserCenter" action="/UserCenter/Save" method="post" enctype="multipart/form-data" class="user-form">
        @Html.AntiForgeryToken()
        
        <!-- 🔴 修复：隐藏域 存储当前头像，提交时保留旧头像 -->
        <input type="hidden" name="oldAvatar" value="@Model?.avatar" />

        <!-- 头像区域 -->
        <div class="form-item avatar-area">
            <label>头像</label>
            <img id="avatar"
                 src="@(string.IsNullOrEmpty(Model?.avatar) ? "/images/avatar/default.png" : Model.avatar)"
                 alt="用户头像">
            <input type="file" id="avatarInput" name="avatar" onchange="previewAvatar(this)">
            <label for="avatarInput">📸 选择头像</label>
        </div>

        <!-- 用户名 -->
        <div class="form-item">
            <label>用户名</label>
            <input type="text" name="username" value="@Model!.username" />
        </div>

        <!-- ID（只读） -->
        <div class="form-item">
            <label>id</label>
            <input type="text" name="id" value="@Model.id" readonly />
        </div>

        <!-- 邮箱 -->
        <div class="form-item">
            <label>邮箱</label>
            <input type="email" name="email" value="@Model.email" />
        </div>

        <!-- 手机号 -->
        <div class="form-item">
            <label>手机号</label>
            <input type="text" name="phone" value="@Model.phone" />
        </div>

        <!-- 年龄 -->
        <div class="form-item">
            <label>年龄</label>
            <input type="text" name="age" value="@Model.age" />
        </div>

        <!-- 性别 -->
        <div class="form-item">
            <label>性别</label>
            <select name="Sex">
                <option value="未知" @(Model.sex == "未知" ? "selected" : "")>未知</option>
                <option value="男" @(Model.sex == "男" ? "selected" :string.Empty)>男</option>
                <option value="女" @(Model.sex == "女" ? "selected" : null)>女</option>
            </select>
        </div>

        <!-- 生日 -->
        <div class="form-item">
            <label>生日</label>
            <input type="date" name="by" value="@(Model.by.HasValue? Model.by.Value.ToString("yyyy-MM-dd") : "")" />
        </div>

        <!-- 个人简介 -->
        <div class="form-item">
            <label>个人简介</label>
            <textarea name="pr" rows="4">@Model.pr</textarea>
        </div>

        <!-- 详细地址 -->
        <div class="form-item">
            <label>详细地址</label>
            <input type="text" name="address" value="@Model.address" />
        </div>

        <!-- 按钮组 -->
        <div class="btn-group">
            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 保存信息</button>
            <button type="reset" class="btn-reset"><i class="fas fa-redo"></i> 重置</button>
            <button type="button" class="btn-back" onclick="window.location.href='@Url.Action("Index", "Home")'">返回主页</button>
        </div>
    </form>
</div>